# ─────────────────────────────────────────────────────────────────────────────
# Profitability Intelligence — API Configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored and NEVER committed to version control.
# After editing .env you MUST restart: npm run dev
# ─────────────────────────────────────────────────────────────────────────────

# ── 1. Your API key ───────────────────────────────────────────────────────────
VITE_API_KEY=your_api_key_here

# ── 2. Base endpoint URL (no trailing slash) ──────────────────────────────────
#  This is the BASE URL only — the app appends the path automatically.
#  Examples:
#    https://your-azure-openai.openai.azure.com
#    https://api.openai.com/v1
#    https://api.anthropic.com
VITE_API_ENDPOINT=https://your-api-gateway-url.com

# ── 3. API format ─────────────────────────────────────────────────────────────
#  openai    → sends { messages:[...], max_completion_tokens:... }
#  anthropic → sends { system:"...", messages:[...] }
VITE_API_FORMAT=openai

# ── 4. Auth header style ──────────────────────────────────────────────────────
#  bearer    → Authorization: Bearer <key>   ← OpenAI / most gateways
#  api-key   → api-key: <key>                ← Azure OpenAI native header
#  x-api-key → x-api-key: <key>              ← Anthropic direct API
VITE_API_AUTH_HEADER=bearer

# ── 5. Model name (optional) ──────────────────────────────────────────────────
#  Leave blank to omit from request body (gateway picks the model).
#  Examples: gpt-4o  |  gpt-4-turbo  |  claude-3-5-sonnet-20241022
VITE_MODEL=

# ── 6. Path override (advanced — only needed if you get 404 errors) ───────────
#  Overrides the auto-appended path. Leave blank in normal use.
#  Examples:
#    /v1/chat/completions
#    /openai/deployments/gpt-4o/chat/completions?api-version=2024-02-01
#    /chat/completions
VITE_API_PATH=
